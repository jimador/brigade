#!/usr/bin/env node
// brigade-bundle — regenerates workflows/<name>.js from workflows/src/<name>.js
// + workflows/config.js.
//
// Workflow scripts run in a context that can't do runtime imports, so the
// shared config has to be spliced into each generated script at build time
// instead of required at run time. Each source file carries a single marker
// line (//@BRIGADE_CONFIG@) that this tool replaces with the full text of
// workflows/config.js, then appends a generated-file trailer.
//
// Usage:
//   brigade-bundle            # bundle every workflows/src/*.js, write outputs
//   brigade-bundle --check    # regenerate in memory, compare to committed
//                              # outputs; exit 1 if anything is stale/missing
import fs from 'node:fs'
import path from 'node:path'
import { fileURLToPath } from 'node:url'

const __dirname = path.dirname(fileURLToPath(import.meta.url))
const ROOT = path.join(__dirname, '..')
const WORKFLOWS_DIR = path.join(ROOT, 'workflows')
const SRC_DIR = path.join(WORKFLOWS_DIR, 'src')
const CONFIG_PATH = path.join(WORKFLOWS_DIR, 'config.js')
const MARKER = '//@BRIGADE_CONFIG@'

function die(msg) {
  process.stderr.write(`brigade-bundle: ${msg}\n`)
  process.exit(1)
}

function readConfigText() {
  if (!fs.existsSync(CONFIG_PATH)) die(`missing config: ${CONFIG_PATH}`)
  return fs.readFileSync(CONFIG_PATH, 'utf8')
}

function listSrcFiles() {
  if (!fs.existsSync(SRC_DIR)) die(`missing src dir: ${SRC_DIR}`)
  const files = fs.readdirSync(SRC_DIR).filter((f) => f.endsWith('.js')).sort()
  if (files.length === 0) die(`empty src dir: ${SRC_DIR}`)
  return files
}

// Normalize text to lines with any single trailing newline stripped, so
// splitting and rejoining is lossless and deterministic. Strip CR so CRLF
// sources don't break the //@BRIGADE_CONFIG@ exact-match check.
function linesOf(text) {
  return text.replace(/\r\n/g, '\n').replace(/\r/g, '\n').replace(/\n$/, '').split('\n')
}

// Build the bundled text for one source file. Dies loudly (with the path)
// if the marker isn't present exactly once.
function bundle(srcPath, configText) {
  const raw = fs.readFileSync(srcPath, 'utf8')
  const srcLines = linesOf(raw)
  const markerLines = srcLines.filter((l) => l === MARKER).length
  if (markerLines !== 1) die(`missing marker ${MARKER} in ${srcPath}`)
  const markerIdx = srcLines.indexOf(MARKER)
  const configLines = linesOf(configText)
  const name = path.basename(srcPath, '.js')
  const trailer = `// GENERATED by bin/brigade-bundle from workflows/src/${name}.js — edit the source, then re-run bin/brigade-bundle`
  const outLines = [
    ...srcLines.slice(0, markerIdx),
    ...configLines,
    ...srcLines.slice(markerIdx + 1),
    trailer,
  ]
  return outLines.join('\n') + '\n'
}

function outputPathFor(srcFile) {
  const name = path.basename(srcFile, '.js')
  return path.join(WORKFLOWS_DIR, `${name}.js`)
}

function runCheck(srcFiles, configText) {
  let stale = false
  for (const f of srcFiles) {
    const expected = bundle(path.join(SRC_DIR, f), configText)
    const outPath = outputPathFor(f)
    const actual = fs.existsSync(outPath) ? fs.readFileSync(outPath, 'utf8') : null
    if (actual !== expected) {
      console.log(`STALE: ${path.relative(ROOT, outPath)}`)
      stale = true
    }
  }
  if (stale) process.exit(1)
  console.log('BUNDLE OK')
  process.exit(0)
}

function runBundle(srcFiles, configText) {
  for (const f of srcFiles) {
    const content = bundle(path.join(SRC_DIR, f), configText)
    const outPath = outputPathFor(f)
    fs.writeFileSync(outPath, content)
    console.log(`bundled ${path.relative(ROOT, outPath)}`)
  }
  process.exit(0)
}

function main() {
  const check = process.argv.includes('--check')
  const configText = readConfigText()
  const srcFiles = listSrcFiles()
  if (check) runCheck(srcFiles, configText)
  else runBundle(srcFiles, configText)
}

main()
